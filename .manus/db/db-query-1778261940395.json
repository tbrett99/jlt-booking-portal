  "query": "UPDATE recruitment_workflow_emails\nSET subject = 'You''re Approved — Here''s How to Get Started with JLT Group',\n    bodyHtml = '<div style=\"font-family:Poppins,sans-serif;max-width:600px;margin:0 auto;background:#ffffff;border-radius:12px;overflow:hidden;border:1px solid #e5e7eb;\">\n  <div style=\"background:#0d1a26;padding:32px 40px;text-align:center;\">\n    <h1 style=\"color:#70FFE8;font-size:24px;font-weight:700;margin:0;\">Welcome to the JLT Group Family!</h1>\n  </div>\n  <div style=\"padding:40px;\">\n    <p style=\"color:#414141;font-size:15px;line-height:1.6;margin:0 0 16px;\">Hi {{firstName}},</p>\n    <p style=\"color:#414141;font-size:15px;line-height:1.6;margin:0 0 24px;\">We are absolutely thrilled to welcome you to the JLT Group team! Your onboarding has been approved and you can now complete your sign-up and get started straight away.</p>\n\n    <p style=\"text-align:center;margin:0 0 32px;\">\n      <a href=\"https://portal.thejltgroup.co.uk/join\" style=\"display:inline-block;background:#02E6D2;color:#0d1a26;font-weight:700;font-size:15px;padding:16px 40px;border-radius:8px;text-decoration:none;\">Complete Your Sign-Up →</a>\n    </p>\n\n    <div style=\"background:#f8fffe;border:1px solid #70FFE8;border-radius:10px;padding:24px;margin:0 0 24px;\">\n      <p style=\"color:#0d1a26;font-weight:700;font-size:14px;margin:0 0 16px;text-transform:uppercase;letter-spacing:0.05em;\">Your Sign-Up Journey</p>\n      <table style=\"width:100%;border-collapse:collapse;\">\n        <tr>\n          <td style=\"padding:10px 0;border-bottom:1px solid #e5e7eb;vertical-align:top;width:32px;\">\n            <span style=\"display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;background:#02E6D2;color:#0d1a26;border-radius:50%;font-weight:700;font-size:12px;\">1</span>\n          </td>\n          <td style=\"padding:10px 0 10px 12px;border-bottom:1px solid #e5e7eb;\">\n            <strong style=\"color:#0d1a26;font-size:14px;\">Select Your Membership Plan</strong>\n            <p style=\"color:#6b7280;font-size:13px;margin:2px 0 0;\">Choose the tier that best suits your business goals.</p>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:10px 0;border-bottom:1px solid #e5e7eb;vertical-align:top;\">\n            <span style=\"display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;background:#02E6D2;color:#0d1a26;border-radius:50%;font-weight:700;font-size:12px;\">2</span>\n          </td>\n          <td style=\"padding:10px 0 10px 12px;border-bottom:1px solid #e5e7eb;\">\n            <strong style=\"color:#0d1a26;font-size:14px;\">Sign the Contract</strong>\n            <p style=\"color:#6b7280;font-size:13px;margin:2px 0 0;\">Review and digitally sign your agent agreement.</p>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:10px 0;border-bottom:1px solid #e5e7eb;vertical-align:top;\">\n            <span style=\"display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;background:#02E6D2;color:#0d1a26;border-radius:50%;font-weight:700;font-size:12px;\">3</span>\n          </td>\n          <td style=\"padding:10px 0 10px 12px;border-bottom:1px solid #e5e7eb;\">\n            <strong style=\"color:#0d1a26;font-size:14px;\">Pay the Joining Fee &amp; Set Up Your Direct Debit</strong>\n            <p style=\"color:#6b7280;font-size:13px;margin:2px 0 0;\">Your joining fee is due now. Your first monthly payment will be taken a <strong>minimum of 28 days</strong> after the joining fee is processed.</p>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:10px 0;border-bottom:1px solid #e5e7eb;vertical-align:top;\">\n            <span style=\"display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;background:#02E6D2;color:#0d1a26;border-radius:50%;font-weight:700;font-size:12px;\">4</span>\n          </td>\n          <td style=\"padding:10px 0 10px 12px;border-bottom:1px solid #e5e7eb;\">\n            <strong style=\"color:#0d1a26;font-size:14px;\">Complete Your Onboarding</strong>\n            <p style=\"color:#6b7280;font-size:13px;margin:2px 0 0;\">Our team will guide you through the final onboarding steps.</p>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:10px 0;vertical-align:top;\">\n            <span style=\"display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;background:#02E6D2;color:#0d1a26;border-radius:50%;font-weight:700;font-size:12px;\">5</span>\n          </td>\n          <td style=\"padding:10px 0 10px 12px;\">\n            <strong style=\"color:#0d1a26;font-size:14px;\">Receive Access to the Training Hub</strong>\n            <p style=\"color:#6b7280;font-size:13px;margin:2px 0 0;\">Get instant access to our full training library and start your journey as a JLT Group travel agent!</p>\n          </td>\n        </tr>\n      </table>\n    </div>\n\n    <p style=\"text-align:center;margin:0 0 24px;\">\n      <a href=\"https://portal.thejltgroup.co.uk/join\" style=\"display:inline-block;background:#02E6D2;color:#0d1a26;font-weight:700;font-size:15px;padding:16px 40px;border-radius:8px;text-decoration:none;\">Get Started Now →</a>\n    </p>\n\n    <p style=\"color:#6b7280;font-size:13px;line-height:1.6;margin:0;\">If you have any questions at any point, do not hesitate to reply to this email — we are here to help every step of the way.</p>\n    <p style=\"color:#414141;font-size:14px;margin:24px 0 0;\">Warm regards,<br/><strong>The JLT Group Team</strong></p>\n  </div>\n  <div style=\"background:#f9fafb;padding:16px 40px;text-align:center;border-top:1px solid #e5e7eb;\">\n    <p style=\"color:#9ca3af;font-size:12px;margin:0;\">JLT Group · <a href=\"https://thejltgroup.co.uk\" style=\"color:#9ca3af;\">thejltgroup.co.uk</a></p>\n  </div>\n</div>'\nWHERE workflowId = (SELECT id FROM recruitment_workflows WHERE stage = 'onboarding_approved')\n  AND stepOrder = 1;",
